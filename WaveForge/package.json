{
  "name": "waveforge",
  "productName": "WaveForge",
  "version": "0.1.0",
  "description": "封面为中心的沉浸式音乐播放器，支持网易云和QQ音乐",
  "author": "WaveForge",
  "type": "module",
  "main": "desktop/main.js",
  "private": true,
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "node local-server.mjs",
    "dev:electron": "node scripts/dev-electron.mjs",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder --win nsis",
    "build:electron:dir": "npm run build && electron-builder --win dir",
    "start": "electron .",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "build": {
    "appId": "com.waveforge.desktop",
    "productName": "WaveForge",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "server/**/*",
      "local-server.mjs",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "executableName": "WaveForge",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "shortcutName": "WaveForge",
      "artifactName": "WaveForge-${version}-Setup.${ext}"
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "color-thief-react": "^2.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.40.0",
    "jsmediatags": "^3.9.7",
    "lucide-react": "^0.546.0",
    "music-metadata-browser": "^2.5.11",
    "NeteaseCloudMusicApi": "^4.32.0",
    "qq-music-api": "^1.1.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsmediatags": "^3.9.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.21",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
